<idea-plugin>
    <id>com.github.technic404.cjsutility</id>
    <name>cjs-utility</name>
    <vendor>technic404</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>JavaScript</depends>
    <extensions defaultExtensionNs="JavaScript">
        <frameworkIndexingHandler implementation="pl.technic404.cjs.CjsFrameworkHandler"/>
        <jsTypeProcessor implementation="pl.technic404.cjs.CjsCallTypeProvider"/>
    </extensions>

    <resource-bundle>messages.MyBundle</resource-bundle>
</idea-plugin>
